\name{enrich_palette}
\alias{enrich_palette}
\title{Enrichment plot palettes}
\description{
Return one of the built-in enrichment plot palettes.
}
\usage{
enrich_palette(name = "journal")
}
\arguments{
\item{name}{Palette name: \code{"classic"}, \code{"journal"}, or \code{"presentation"}.}
}
\value{A list containing the normalized palette \code{name}, gradient colors,
optional gradient \code{values}, and accent color.}
